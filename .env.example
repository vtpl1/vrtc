# Copy this file to .env and fill in real values.
# Viper picks these up automatically via AutomaticEnv().
# Key mapping: config key dots become underscores, all uppercase.
# e.g.  edge.mysql_conn_str  ->  EDGE_MYSQL_CONN_STR

# ── Edge service ──────────────────────────────────────────────────────────────
EDGE_SRC_ADDR=http://live_rec_service:20006"
EDGE_SINK_ADDR=http://${MASTER_SERVER_IP}:20003

EDGE_MYSQL_CONN_STR=user:password@tcp(127.0.0.1:3306)/ivms_30
EDGE_MONGO_CONN_STR=mongodb://user:password@127.0.0.1:27017/

# ── Cloud service ─────────────────────────────────────────────────────────────
CLOUD_MONGO_CONN_STR=mongodb://user:password@127.0.0.1:27017/

# ── Edge service (credentials) ────────────────────────────────────────────────
# Prefix: EDGE_  (config.<key> → EDGE_<KEY>)
EDGE_MYSQL_CONFIG_USERNAME=root
EDGE_MYSQL_CONFIG_PASSWORD=changeme
